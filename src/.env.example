# ===== Application =====
APP_NAME=Personal External Memory
APP_VERSION=0.1.0
APP_DESCRIPTION=Personal relationship management system
DEBUG=True

# ===== Server =====
HOST=127.0.0.1
PORT=8000
RELOAD=True
# Public base URI used for externally visible links and callbacks (optional)
# BASE_URI=https://your-domain

# ===== Database =====
# SQLite: sqlite:///./data.db or sqlite+aiosqlite:///./data.db (for async)
DATABASE_URL=sqlite+aiosqlite:///./pem.db

# ===== Security =====
# Secret key for signing JWT tokens (generate with: openssl rand -hex 32)
SECRET_KEY=your-secret-key-change-in-production

# JWT configuration
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== CORS =====
CORS_ORIGINS=["http://localhost", "http://localhost:3000", "http://localhost:8080"]

# ===== Logging =====
LOG_LEVEL=INFO

# ===== Geocoding (Nominatim) =====
# Recommended for operational contact; not required when User-Agent identifies your app
NOMINATIM_CONTACT_EMAIL=you@example.com
# Optional overrides
# NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
# NOMINATIM_MIN_INTERVAL_SECONDS=1.0

# ===== External Integrations (optional - for future use) =====
# GOOGLE_CALENDAR_API_KEY=
# OUTLOOK_API_KEY=
# IMMICH_API_URL=
# IMMICH_API_KEY=

# ===== OpenID Connect SSO (optional) =====
# OPENID_ISSUER_URL=https://accounts.example.com
# OPENID_CLIENT_ID=your-client-id
# OPENID_CLIENT_SECRET=your-client-secret
# OPENID_SSO_BUTTON_TEXT=Sign in with Example SSO
